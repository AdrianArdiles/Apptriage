# Base de datos (Prisma). SQLite por defecto para desarrollo.
DATABASE_URL="file:./prisma/dev.db"

# URL base de la API. En desarrollo (localhost) se usa el mismo origen si no se define.
# En producción / APK: definir en Vercel (Environment Variables) y/o en .env.production.
# Ejemplo: NEXT_PUBLIC_API_URL=https://apptriage.vercel.app
# NEXT_PUBLIC_API_URL=

# Opcional: para categorizar con OpenAI en lugar del fallback por reglas.
OPENAI_API_KEY=

# ========== Google Sign-In (obligatorio para "Continuar con Google") ==========
# 1) Firebase Console → Authentication → Sign-in method → Google → habilitar y copiar "ID de cliente web".
# 2) Pegar aquí (debe terminar en .apps.googleusercontent.com). Sin esto el botón Google falla.
# NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=tu_id.apps.googleusercontent.com
