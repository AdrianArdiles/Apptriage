<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Ultra permisivo: cleartext y confianza en system + user -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    <!-- API en Vercel -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">apptriage.vercel.app</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
    <!-- Firebase Auth y Google (identitytoolkit, securetoken, googleapis); evita bloqueos por política de red -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">identitytoolkit.googleapis.com</domain>
        <domain includeSubdomains="true">securetoken.googleapis.com</domain>
        <domain includeSubdomains="true">firebaseapp.com</domain>
        <domain includeSubdomains="true">googleapis.com</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
</network-security-config>
