rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Solo usuarios autenticados pueden leer y escribir
    match /authorized_users/{doc} {
      allow read, write: if request.auth != null;
    }
    match /atenciones/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
