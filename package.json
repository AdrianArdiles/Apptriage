{
  "name": "triage-medico",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "app:build": "next build && npx cap sync",
    "build:android": "node scripts/hide-api-for-export.js && npm run build && node scripts/restore-api-after-export.js && npx cap copy android && npx cap sync android",
    "build:android:clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true}); require('fs').rmSync('.next',{recursive:true,force:true});\" && npm run build:android",
    "prebuild:capacitor": "node scripts/prebuild-capacitor.js",
    "postbuild:capacitor": "node scripts/postbuild-capacitor.js",
    "cap:copy": "npm run build:android",
    "build:mobile": "npm run build && npx cap copy android && npx cap sync android",
    "dev": "next dev",
    "dev:network": "next dev --hostname 0.0.0.0",
    "build": "prisma generate && next build",
    "build:web": "cross-env BUILD_WEB=1 prisma generate && next build",
    "build:hosting": "prisma generate && next build",
    "deploy:hosting": "npm run build:hosting && firebase deploy --only hosting",
    "deploy:vercel": "npx vercel --prod",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@capacitor-community/file-opener": "^8.0.0",
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@prisma/client": "^5.0.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "firebase": "^12.10.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "next": "^15.0.0",
    "openai": "^4.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^2.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "prisma": "^5.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0"
  }
}
